# This file controls what gets uploaded to Cloud Build.
# Without this file, gcloud falls back to .gitignore which excludes yarn.lock.

.git
.gitignore
node_modules
npm-debug.log
.env
.env.local
.env.*.local
dist
build
*.tsbuildinfo
*.log
.DS_Store
.vscode
.idea
README.md
GOOGLE_CLOUD_SETUP.md
docker-compose.yml
docker-regen.sh
docker-retro.sh
regen-townhalls.sh
env.example
