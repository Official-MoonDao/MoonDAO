  "sharedGoals": [
    {
      "id": "shared-landing-pads",
      "title": "First demonstrated lunar landing-pad construction system",
      "description": "Soft regolith and lander plumes threaten every sustained surface operation — hardened landing pads, roads, and berms are the first infrastructure any base needs. Multiple companies are racing this capability with genuinely different technology bets: laser/large-scale printing (ICON), microwave sintering (Redwire), molten-regolith bricks (Astroport), and regolith-polymer printing (AI SpaceFactory). A future MoonDAO DePrize would reward the first team to meet the frozen capability criteria below.",
      "projectIds": [
        "icon-project-olympus",
        "redwire-mason",
        "astroport-lunatron",
        "ai-spacefactory-react"
      ],
      "location": {
        "lat": -88,
        "lon": 60
      },
      "regionLabel": "Lunar South Pole — candidate construction zone",
      "criteria": [
        {
          "id": "pad-surface",
          "statement": "Produce a continuous load-bearing surface from lunar regolith simulant",
          "threshold": "≥ 25 m²; ≥ 90% regolith feedstock by mass"
        },
        {
          "id": "plume-load",
          "statement": "Survive a published plume / mechanical load profile",
          "threshold": "MoonDAO-frozen spec derived from NASA/ESA plume-surface interaction data"
        },
        {
          "id": "environment",
          "statement": "Demonstrate the process in a relevant environment",
          "threshold": "Vacuum and/or lunar thermal extremes; exact bar frozen at market open"
        },
        {
          "id": "open-data",
          "statement": "Publish an open performance data pack for peer review and simulation use",
          "threshold": "Strength, thickness, energy per kg, dust shedding"
        },
        {
          "id": "budget-gate",
          "statement": "Quote a CLPS-class flight demonstration within budget",
          "threshold": "Quote ≤ prize-pool TWAP at market close"
        }
      ],
      "targetWindow": {
        "from": "2026",
        "to": "2032"
      },
      "market": {
        "status": "planned",
        "resolutionAuthority": "senate",
        "payoutSplit": {
          "capability": 0.3,
          "flight": 0.7
