  "sharedGoals": [
    {
      "id": "shared-south-pole-base",
      "title": "First sustained crewed South Pole presence",
      "description": "Multiple organizations are racing to land and sustain crews at the lunar South Pole. NASA's Artemis campaign anchors the goal, with SpaceX and Blue Origin providing the landers that deliver astronauts to the surface.",
      "projectIds": [
        "nasa-artemis-base-camp",
        "nasa-artemis-iii",
        "spacex-starship-hls",
        "blue-origin-blue-moon-mk2"
      ],
